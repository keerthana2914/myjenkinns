pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'github-ssh',
                    url: 'git@github.com:keerthana2914/myproject.git'
            }
        }

        stage('Build') {
            steps {
                sh 'gcc hello.c -o hello'
            }
        }

        stage('Run') {
            steps {
                sh './hello'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'hello', fingerprint: true
            }
        }
    }
}
