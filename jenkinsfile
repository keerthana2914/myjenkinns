pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'github-ssh',
                    url: 'git@github.com:keerthana2914/myjenkinns.git'
            }
        }

        stage('Build') {
            steps {
                sh 'gcc add.c -o add'
            }
        }

        stage('Run') {
            steps {
                sh './add'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'add', fingerprint: true
            }
        }
    }
}
